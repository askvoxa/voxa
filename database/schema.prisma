generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Pode ser alterado para "mysql", "sqlite", etc.
  url      = env("DATABASE_URL")
}

model Profile {
  id                       String          @id @default(uuid())
  username                 String          @unique
  bio                      String?
  avatar_url               String?
  min_price                Float           @default(10.0)
  daily_limit              Int             @default(10)
  questions_answered_today Int             @default(0)
  referred_by_id           String?
  is_admin                 Boolean         @default(false)
  is_active                Boolean         @default(true)
  // Individual overrides — null = use platform default from platform_settings
  custom_creator_rate      Decimal?        @db.Decimal(5, 4)
  custom_deadline_hours    Int?
  created_at               DateTime        @default(now())
  referred_by              Profile?        @relation("Referrals", fields: [referred_by_id], references: [id], onDelete: SetNull)
  referrals                Profile[]       @relation("Referrals")
  questions                Question[]
  payment_intents          PaymentIntent[]

  @@map("profiles")
}

enum QuestionStatus {
  pending
  answered
  expired
}

model Question {
  id                 String         @id @default(uuid())
  creator_id         String
  creator            Profile        @relation(fields: [creator_id], references: [id], onDelete: Cascade)
  sender_name        String
  content            String
  media_url          String?
  status             QuestionStatus @default(pending)
  price_paid         Float
  service_type       String         @default("base")
  is_anonymous       Boolean        @default(false)
  is_shareable       Boolean        @default(false)
  response_text      String?
  response_audio_url String?
  answered_at        DateTime?
  created_at         DateTime       @default(now())
  transactions       Transaction[]

  @@map("questions")
}

model Transaction {
  id               String   @id @default(uuid())
  question_id      String
  question         Question @relation(fields: [question_id], references: [id], onDelete: Cascade)
  amount           Float
  status           String
  payment_method   String
  mp_payment_id    String?
  mp_preference_id String?
  created_at       DateTime @default(now())

  @@map("transactions")
}

// Tabela temporária — armazena dados da pergunta durante o fluxo de pagamento MP.
// Deletada pelo webhook após confirmação do pagamento.
model PaymentIntent {
  id               String   @id @default(uuid())
  creator_id       String
  creator          Profile  @relation(fields: [creator_id], references: [id], onDelete: Cascade)
  question_data    Json
  amount           Decimal  @db.Decimal(10, 2)
  mp_preference_id String?
  created_at       DateTime @default(now())

  @@map("payment_intents")
}

// Configurações globais da plataforma (singleton — id = 1).
// Gerenciado pelo admin em /admin/settings.
model PlatformSettings {
  id                      Int      @id @default(1)
  platform_fee_rate       Decimal  @default(0.1000) @db.Decimal(5, 4)
  response_deadline_hours Int      @default(36)
  updated_at              DateTime @default(now())

  @@map("platform_settings")
}

// Fila de reembolsos — perguntas expiradas (>36h sem resposta) aguardando reembolso no MP.
// Processada por /api/refunds/process (cron externo ou Render.com Cron Jobs).
model RefundQueue {
  id            String    @id @default(uuid())
  question_id   String
  mp_payment_id String
  amount        Decimal   @db.Decimal(10, 2)
  status        String    @default("pending") // pending | processed | failed
  created_at    DateTime  @default(now())
  processed_at  DateTime?

  @@map("refund_queue")
}
