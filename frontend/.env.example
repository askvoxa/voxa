# ============================================================
# Supabase — obrigatório
# Encontre em: supabase.com > Settings > API
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Supabase Service Role Key (apenas server-side, nunca expor ao cliente)
# Encontre em: supabase.com > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ============================================================
# Mercado Pago — obrigatório para pagamentos
# Encontre em: mercadopago.com.br > Suas integrações > Credenciais
# ============================================================
MP_ACCESS_TOKEN=APP_USR-...
NEXT_PUBLIC_MP_PUBLIC_KEY=APP_USR-...

# ============================================================
# App URL — usado para webhook e redirects do MP
# Em desenvolvimento: http://localhost:3000
# Em produção: https://seu-dominio.com
# IMPORTANTE: Use o domínio canônico (sem www) para evitar redirects
# que quebram webhooks do Mercado Pago (ex: https://askvoxa.com)
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# Segurança — chaves secretas para endpoints protegidos
# ============================================================

# Secret para verificação de assinatura do webhook do Mercado Pago
# Encontre em: mercadopago.com.br > Suas integrações > Webhooks > Secret
MP_WEBHOOK_SECRET=

# Secret para proteger o endpoint de processamento de reembolsos (/api/refunds/process)
# Gere qualquer string aleatória longa: openssl rand -hex 32
REFUND_SECRET=

# Feature flag — reembolsos automáticos após 36h via cron job
# Habilitar após configurar os Cron Jobs no Render.com (plano Starter ou superior)
FEATURE_REFUNDS_ENABLED=false

# Secret para proteger os endpoints de cron (/api/cron/*)
# Gere com: openssl rand -hex 32
# Configurar também no Render.com > Cron Jobs como header: x-cron-secret
CRON_SECRET=

# Prazo de resposta em horas (padrão: 36)
RESPONSE_DEADLINE_HOURS=36

# ============================================================
# Resend — notificações por email para fãs
# Encontre em: resend.com > API Keys
# ============================================================
RESEND_API_KEY=re_...

# ============================================================
# Upstash Redis — rate limiting persistente para saques (opcional)
# Encontre em: console.upstash.com > Databases > REST API
# Se não configurado: usa fallback in-memory (apenas dev local)
# ============================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================================
# Payout System — segurança de saques
# ============================================================

# Secret para proteger endpoints de processamento de payouts (/api/cron/process-payouts, /api/cron/release-earnings)
# Gere com: openssl rand -hex 32
PAYOUT_SECRET=

# Chave de criptografia para armazenar chaves PIX dos criadores (LGPD compliance)
# Gere com: openssl rand -hex 16 (32 caracteres hex)
# IMPORTANTE: Esta chave é crítica para a privacidade dos dados
PIX_ENCRYPTION_KEY=
